}

class UserEnumerationProtection {

    public static function init() {
        // Skip protections for WP-CLI commands.
        if ( defined( 'WP_CLI' ) && WP_CLI ) {
            return;
        }
        add_action( 'init', [ __CLASS__, 'block_author_query' ] );
        add_filter( 'rest_pre_dispatch', [ __CLASS__, 'block_rest_users' ], 10, 3 );
        add_filter( 'wp_sitemaps_add_provider', [ __CLASS__, 'remove_author_sitemap' ], 10, 2 );
        add_filter( 'oembed_response_data', [ __CLASS__, 'remove_oembed_author_url' ] );
        add_action( 'template_redirect', [ __CLASS__, 'block_author_archives' ] );
        add_filter( 'login_errors', [ __CLASS__, 'generic_login_error' ] );
        add_filter( 'wpseo_sitemap_exclude_author', '__return_true' );
        remove_action( 'wp_head', 'wp_generator' );
        add_filter( 'the_generator', '__return_empty_string' );
    }

    /**
     * Block ?author=N enumeration for non-logged-in users.
     */
    public static function block_author_query() {
        if ( is_user_logged_in() || is_admin() ) {
            return;
        }
        if ( isset( $_REQUEST['author'] ) && is_numeric( $_REQUEST['author'] ) ) {
            wp_die( 'Forbidden', 'Forbidden', [ 'response' => 403 ] );
        }
    }

    /**
     * Block REST API /wp/v2/users for unauthenticated users.
     */
    public static function block_rest_users( $result, $server, $request ) {
        if ( $result !== null ) {
            return $result;
        }
        $route = $request->get_route();
        if ( preg_match( '#^/wp/v2/users#', $route ) && ! is_user_logged_in() ) {
            return new \WP_Error(
                'rest_user_cannot_view',
                'User enumeration is not allowed.',
                [ 'status' => 401 ]
            );
        }
        return $result;
    }

    /**
     * Remove author/user sitemap provider.
     */
    public static function remove_author_sitemap( $provider, $name ) {
        if ( $name === 'users' ) {
            return false;
        }
        return $provider;
    }

    /**
     * Strip author_url from oEmbed responses.
     */
    public static function remove_oembed_author_url( $data ) {
        if ( isset( $data['author_url'] ) ) {
            unset( $data['author_url'] );
        }
        return $data;
    }

    /**
     * Return 404 for author archives with no published posts.
     *
     * WordPress renders empty author archives for any valid user,
     * which lets bots confirm usernames exist by comparing the
     * response to a non-existent user. This forces a real 404 for
     * authors with no posts, while leaving active author archives
     * (with published content) fully accessible.
     */
    public static function block_author_archives() {
        if ( ! is_author() || is_user_logged_in() ) {
            return;
        }
        $author = get_queried_object();
        if ( ! $author || ! isset( $author->ID ) ) {
            return;
        }
        $post_count = (int) count_user_posts( $author->ID, 'post', true );
        if ( $post_count === 0 ) {
            global $wp_query;
            $wp_query->set_404();
            $wp_query->set( 'author_name', '' );
            $wp_query->set( 'author', 0 );
            $wp_query->queried_object    = null;
            $wp_query->queried_object_id = 0;
            status_header( 404 );
            nocache_headers();
            // Override Yoast and default WordPress title to prevent
            // leaking the author slug in the <title> tag.
            add_filter( 'wpseo_title', [ __CLASS__, 'force_404_title' ], 999 );
            add_filter( 'pre_get_document_title', [ __CLASS__, 'force_404_title' ], 999 );
            add_filter( 'wp_title', [ __CLASS__, 'force_404_title' ], 999 );
            $template = get_404_template();
            if ( $template ) {
                include $template;
            }
            exit;
        }
    }

    /**
     * Return a generic login error message for non-logged-in users.
     *
     * WordPress default messages reveal whether a username exists
     * ("incorrect password" vs "username does not exist"). This
     * replaces both with a single generic message.
     */
    public static function generic_login_error( $error ) {
        return '<strong>Error:</strong> Invalid username or password.';
    }

    /**
     * Override the page title to a generic 404 message.
     *
     * Prevents the author slug from leaking in the <title> tag when
     * a zero-post author archive is forced to 404.
     */
    public static function force_404_title( $title ) {
        $name = get_bloginfo( 'name', 'display' );
        return "Page Not Found - $name";
    }
}

/**
 * Class SecurityPatchUpdater
 *
 * Checks updates.captaincore.io for security patches and injects them
 * into WordPress's native plugin/theme update system.
 */
class SecurityPatchUpdater {

	const UPDATE_URL = 'https://updates.captaincore.io/manifest.json';
	const CACHE_KEY  = 'captaincore_security_patches';
	const CACHE_TTL  = 6 * HOUR_IN_SECONDS;

	public function __construct() {
		add_filter( 'site_transient_update_plugins', [ $this, 'check_plugin_updates' ] );
		add_filter( 'site_transient_update_themes', [ $this, 'check_theme_updates' ] );
		add_filter( 'plugins_api', [ $this, 'plugin_info' ], 20, 3 );
	}

	/**
	 * Fetch the patch manifest from the CDN, cached locally.
	 */
	private function get_manifest() {
		$cached = get_transient( self::CACHE_KEY );
		if ( false !== $cached ) {
			return $cached;
		}

		$response = wp_remote_get( self::UPDATE_URL, [ 'timeout' => 10 ] );
		if ( is_wp_error( $response ) || wp_remote_retrieve_response_code( $response ) !== 200 ) {
			// Cache the failure briefly to avoid hammering on errors.
			set_transient( self::CACHE_KEY, [], 5 * MINUTE_IN_SECONDS );
			return [];
		}

		$body = json_decode( wp_remote_retrieve_body( $response ), true );
		$patches = $body['patches'] ?? [];
		set_transient( self::CACHE_KEY, $patches, self::CACHE_TTL );
		return $patches;
	}

	/**
	 * Inject security patches into plugin update transient.
	 */
	public function check_plugin_updates( $transient ) {
		if ( empty( $transient->checked ) ) {
			return $transient;
		}

		$patches = $this->get_manifest();
		if ( empty( $patches ) ) {
			return $transient;
		}

		foreach ( $transient->checked as $plugin_file => $installed_version ) {
			$slug = dirname( $plugin_file );
			$key  = "plugin|{$slug}|{$installed_version}";

			if ( isset( $patches[ $key ] ) ) {
				$patch = $patches[ $key ];
				$response              = new \stdClass();
				$response->slug        = $slug;
				$response->plugin      = $plugin_file;
				$response->new_version = $patch['patched_version'];
				$response->package     = $patch['download_url'];
				$response->url         = '';
				$transient->response[ $plugin_file ] = $response;
			}
		}

		return $transient;
	}

	/**
	 * Inject security patches into theme update transient.
	 */
	public function check_theme_updates( $transient ) {
		if ( empty( $transient->checked ) ) {
			return $transient;
		}

		$patches = $this->get_manifest();
		if ( empty( $patches ) ) {
			return $transient;
		}

		foreach ( $transient->checked as $theme_slug => $installed_version ) {
			$key = "theme|{$theme_slug}|{$installed_version}";

			if ( isset( $patches[ $key ] ) ) {
				$patch = $patches[ $key ];
				$transient->response[ $theme_slug ] = [
					'theme'       => $theme_slug,
					'new_version' => $patch['patched_version'],
					'package'     => $patch['download_url'],
					'url'         => '',
				];
			}
		}

		return $transient;
	}

	/**
	 * Provide plugin details when user clicks "View details" for a security patch.
	 */
	public function plugin_info( $response, $action, $args ) {
		if ( 'plugin_information' !== $action || ! empty( $response ) || empty( $args->slug ) ) {
			return $response;
		}

		$patches = $this->get_manifest();
		if ( empty( $patches ) ) {
			return $response;
		}

		// Find a patch matching this slug.
		foreach ( $patches as $key => $patch ) {
			if ( $patch['slug'] === $args->slug && $patch['type'] === 'plugin' ) {
				$response                = new \stdClass();
				$response->name          = $patch['title'] ?: $args->slug;
				$response->slug          = $args->slug;
				$response->version       = $patch['patched_version'];
				$response->download_link = $patch['download_url'];
				$response->trunk         = $patch['download_url'];
				$response->author        = 'CaptainCore Security';
				$response->requires      = '5.0';
				$response->tested        = get_bloginfo( 'version' );
				$response->sections      = [
					'description' => $patch['description'] ?: "Security patch for {$patch['slug']} v{$patch['version']}.",
					'changelog'   => "<p><strong>Security Update ({$patch['severity']})</strong></p><p>{$patch['description']}</p>",
				];
				return $response;
			}
		}

		return $response;
	}
}

/**
 * Class PasswordSecurity
 *
 * Checks passwords against the Have I Been Pwned range API using k-anonymity
 * (the public SHA-1 prefix protocol documented at haveibeenpwned.com/API/v3).
 * Blocks compromised logins for enforced roles and warns everyone else until
 * they change their password.
 *
 * Heavily inspired by Passwords Evolved by Carl Alexander
 * (https://github.com/carlalexander/passwords-evolved). This is an independent
 * implementation, not derived from or based on that plugin's source code.
 *
 * Requires WP 6.8+ (native bcrypt + wp_password_needs_rehash). On older WP the
 * bootstrap skips this class entirely.
 */
class PasswordSecurity {

    const OPTION_ENFORCED_ROLES = 'captaincore_password_enforced_roles';
    const META_COMPROMISED_AT   = 'captaincore_password_compromised_at';
    const META_LAST_CHECK       = 'captaincore_password_last_check';
    const TRANSIENT_HIBP_DOWN   = 'captaincore_hibp_down';
    const HIBP_ENDPOINT         = 'https://api.pwnedpasswords.com/range/';
    const SETTINGS_SLUG         = 'captaincore-password-security';

    public static function init() {
        add_filter( 'authenticate',             [ __CLASS__, 'check_login' ], 99, 3 );
        add_filter( 'validate_password_reset',  [ __CLASS__, 'check_reset' ], 10, 2 );
        add_action( 'profile_update',           [ __CLASS__, 'clear_flag_on_password_change' ], 10, 2 );
        add_action( 'after_password_reset',     [ __CLASS__, 'clear_flag_after_reset' ], 10, 1 );
        add_action( 'all_admin_notices',        [ __CLASS__, 'warning_notice' ] );
        add_action( 'admin_menu',               [ __CLASS__, 'register_settings_page' ] );
        add_action( 'admin_init',               [ __CLASS__, 'register_setting' ] );

        if ( defined( 'WP_CLI' ) && WP_CLI ) {
            \WP_CLI::add_command( 'captaincore password check',   [ __CLASS__, 'cli_check_password' ] );
            \WP_CLI::add_command( 'captaincore password flagged', [ __CLASS__, 'cli_list_flagged' ] );
        }
    }

    /**
     * Returns the list of roles that enforce (block) compromised passwords.
     * Defaults to every role that has manage_options.
     */
    private static function get_enforced_roles() {
        $saved = get_option( self::OPTION_ENFORCED_ROLES, null );
        if ( is_array( $saved ) ) {
            return $saved;
        }
        return self::get_default_enforced_roles();
    }

    private static function get_default_enforced_roles() {
        $defaults = [];
        foreach ( wp_roles()->role_objects as $slug => $role ) {
            if ( ! empty( $role->capabilities['manage_options'] ) ) {
                $defaults[] = $slug;
            }
        }
        return $defaults ? $defaults : [ 'administrator' ];
    }

    /**
     * Check HIBP. Returns true (compromised), false (clean), or null (API down).
     * Fails open so a broken network never locks users out.
     */
    private static function is_password_compromised( $password ) {
        if ( ! is_string( $password ) || $password === '' ) {
            return false;
        }

        $hash   = strtoupper( sha1( $password ) );
        $prefix = substr( $hash, 0, 5 );
        $suffix = substr( $hash, 5 );

        $response = wp_remote_get( self::HIBP_ENDPOINT . $prefix, [
            'timeout'    => 3,
            'user-agent' => 'CaptainCoreHelper/1.0 (+https://captaincore.io)',
            'headers'    => [ 'Add-Padding' => 'true' ],
        ] );

        if ( is_wp_error( $response ) ) {
            set_transient( self::TRANSIENT_HIBP_DOWN, $response->get_error_message(), 5 * MINUTE_IN_SECONDS );
            return null;
        }

        $code = (int) wp_remote_retrieve_response_code( $response );
        if ( 200 !== $code ) {
            set_transient( self::TRANSIENT_HIBP_DOWN, 'HTTP ' . $code, 5 * MINUTE_IN_SECONDS );
            return null;
        }

        delete_transient( self::TRANSIENT_HIBP_DOWN );

        $body = wp_remote_retrieve_body( $response );
        foreach ( preg_split( "/\r?\n/", $body ) as $line ) {
            $parts = explode( ':', $line, 2 );
            if ( strcasecmp( trim( $parts[0] ), $suffix ) === 0 ) {
                return ( isset( $parts[1] ) && (int) trim( $parts[1] ) > 0 );
            }
        }
        return false;
    }

    /**
     * Enforce or warn on successful authentication. Checks role membership
     * directly so users with multiple roles are evaluated correctly.
     */
    public static function check_login( $user, $username, $password ) {
        if ( ! $user instanceof \WP_User ) {
            return $user;
        }

        $result = self::is_password_compromised( $password );
        if ( true !== $result ) {
            return $user;
        }

        update_user_meta( $user->ID, self::META_LAST_CHECK, time() );

        $enforced = self::get_enforced_roles();
        $enforce  = (bool) array_intersect( (array) $user->roles, $enforced );

        self::log_event( $enforce ? 'password_compromised_blocked' : 'password_compromised_warned', [
            'user_login' => $user->user_login,
            'roles'      => $user->roles,
        ], $user->ID );

        if ( $enforce ) {
            return new \WP_Error(
                'captaincore_password_compromised',
                sprintf(
                    // translators: %s: lost-password URL
                    __( '<strong>Sign-in blocked.</strong> Your password has appeared in a public data breach. <a href="%s">Reset it</a> before signing in.', 'captaincore-helper' ),
                    esc_url( wp_lostpassword_url() )
                )
            );
        }

        update_user_meta( $user->ID, self::META_COMPROMISED_AT, time() );
        return $user;
    }

    /**
     * Block compromised passwords during reset. Fails open on API errors.
     */
    public static function check_reset( \WP_Error $errors, $user ) {
        if ( empty( $_POST['pass1'] ) || ! $user instanceof \WP_User || $errors->get_error_code() ) {
            return $errors;
        }
        // phpcs:ignore WordPress.Security.ValidatedSanitizedInput
        $new_password = wp_unslash( $_POST['pass1'] );
        if ( true === self::is_password_compromised( $new_password ) ) {
            $errors->add(
                'captaincore_password_compromised',
                __( 'That password has appeared in a public data breach. Please choose a different password.', 'captaincore-helper' )
            );
        }
        return $errors;
    }

    public static function clear_flag_on_password_change( $user_id, $old_user_data ) {
        if ( ! isset( $_POST['pass1'] ) || $_POST['pass1'] === '' ) {
            return;
        }
        delete_user_meta( $user_id, self::META_COMPROMISED_AT );
    }

    public static function clear_flag_after_reset( $user ) {
        if ( $user instanceof \WP_User ) {
            delete_user_meta( $user->ID, self::META_COMPROMISED_AT );
        }
    }

    /**
     * Persistent warning for flagged users until their password is changed.
     */
    public static function warning_notice() {
        $user_id = get_current_user_id();
        if ( ! $user_id ) {
            return;
        }
        $flagged_at = (int) get_user_meta( $user_id, self::META_COMPROMISED_AT, true );
        if ( ! $flagged_at ) {
            return;
        }
        printf(
            '<div class="notice notice-error"><p><strong>%s</strong> %s</p></div>',
            esc_html__( 'Security alert:', 'captaincore-helper' ),
            sprintf(
                // translators: %s: profile edit URL
                wp_kses_post( __( 'your current password has appeared in a public data breach. <a href="%s">Change it now</a> to clear this warning.', 'captaincore-helper' ) ),
                esc_url( get_edit_profile_url( $user_id ) . '#password' )
            )
        );
    }

    // ----- Settings page -----

    public static function register_setting() {
        register_setting( self::SETTINGS_SLUG, self::OPTION_ENFORCED_ROLES, [
            'type'              => 'array',
            'sanitize_callback' => [ __CLASS__, 'sanitize_enforced_roles' ],
            'default'           => self::get_default_enforced_roles(),
        ] );
    }

    public static function sanitize_enforced_roles( $value ) {
        if ( ! is_array( $value ) ) {
            return [];
        }
        $valid = array_keys( wp_roles()->role_objects );
        return array_values( array_intersect( $valid, array_map( 'sanitize_key', $value ) ) );
    }

    public static function register_settings_page() {
        add_users_page(
            __( 'Password Security', 'captaincore-helper' ),
            __( 'Password Security', 'captaincore-helper' ),
            'manage_options',
            self::SETTINGS_SLUG,
            [ __CLASS__, 'render_settings_page' ]
        );
    }

    public static function render_settings_page() {
        if ( ! current_user_can( 'manage_options' ) ) {
            return;
        }
        $enforced = self::get_enforced_roles();
        $down     = get_transient( self::TRANSIENT_HIBP_DOWN );
        ?>
        <div class="wrap">
            <h1><?php esc_html_e( 'Password Security', 'captaincore-helper' ); ?></h1>
            <p><?php esc_html_e( 'Check user passwords against the Have I Been Pwned database. Enforced roles are blocked from signing in with a compromised password; all other users get a persistent admin warning until they change it.', 'captaincore-helper' ); ?></p>
            <?php if ( $down ) : ?>
                <div class="notice notice-warning"><p>
                    <?php
                    printf(
                        // translators: %s: underlying HIBP error message
                        esc_html__( 'HIBP API is currently unreachable (%s). Logins are failing open — compromised passwords will not be blocked until the API recovers.', 'captaincore-helper' ),
                        esc_html( $down )
                    );
                    ?>
                </p></div>
            <?php endif; ?>
            <form method="post" action="options.php">
                <?php settings_fields( self::SETTINGS_SLUG ); ?>
                <table class="form-table" role="presentation"><tbody>
                    <tr>
                        <th scope="row"><?php esc_html_e( 'Enforced roles', 'captaincore-helper' ); ?></th>
                        <td>
                            <?php foreach ( wp_roles()->role_objects as $slug => $role ) : ?>
                                <label style="display:block;margin-bottom:4px;">
                                    <input type="checkbox"
                                           name="<?php echo esc_attr( self::OPTION_ENFORCED_ROLES ); ?>[]"
                                           value="<?php echo esc_attr( $slug ); ?>"
                                           <?php checked( in_array( $slug, $enforced, true ) ); ?> />
                                    <?php echo esc_html( translate_user_role( $role->name ) ); ?>
                                </label>
                            <?php endforeach; ?>
                            <p class="description">
                                <?php esc_html_e( 'Defaults to every role with the manage_options capability.', 'captaincore-helper' ); ?>
                            </p>
                        </td>
                    </tr>
                </tbody></table>
                <?php submit_button(); ?>
            </form>
        </div>
        <?php
    }

    // ----- SecurityLogger integration (best-effort, no hard dependency) -----

    private static function log_event( $action, array $data, $user_id = null ) {
        if ( method_exists( __NAMESPACE__ . '\\SecurityLogger', 'log_public' ) ) {
            SecurityLogger::log_public( $action, $data, $user_id );
        }
    }

    // ----- WP-CLI -----

    /**
     * Check a password against HIBP without signing in.
     *
     * ## OPTIONS
     *
     * <password>
     * : Plain-text password to check.
     *
     * @param array $args
     */
    public static function cli_check_password( $args ) {
        if ( empty( $args[0] ) ) {
            \WP_CLI::error( 'Password argument is required.' );
        }
        $result = self::is_password_compromised( $args[0] );
        if ( null === $result ) {
            \WP_CLI::warning( 'HIBP API unreachable — result unknown.' );
            return;
        }
        \WP_CLI::log( $result ? 'compromised' : 'clean' );
    }

    /**
     * List users flagged as having compromised passwords.
     */
    public static function cli_list_flagged() {
        $users = get_users( [
            'meta_key'     => self::META_COMPROMISED_AT,
            'meta_compare' => 'EXISTS',
            'fields'       => [ 'ID', 'user_login', 'user_email' ],
        ] );
        if ( ! $users ) {
            \WP_CLI::log( 'No flagged users.' );
            return;
        }
        $rows = array_map( function ( $u ) {
            return [
                'ID'         => $u->ID,
                'login'      => $u->user_login,
                'email'      => $u->user_email,
                'flagged_at' => gmdate( 'Y-m-d H:i:s', (int) get_user_meta( $u->ID, self::META_COMPROMISED_AT, true ) ),
            ];
        }, $users );
        \WP_CLI\Utils\format_items( 'table', $rows, [ 'ID', 'login', 'email', 'flagged_at' ] );
    }
}

