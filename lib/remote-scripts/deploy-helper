    public static function log_core_update( $update_results ) {
        self::log( 'system_core_updated', [ 'new_version' => $update_results, 'update_method' => 'manual' ] );
    }

    public static function log_automatic_updates_complete( $results ) {
        if ( empty( $results ) ) { return; }
        if ( isset( $results['core'][0] ) ) {
            $core = $results['core'][0];
            self::log( 'system_core_updated', [
                'new_version'   => $core->item->version,
                'old_version'   => $core->item->current_version ?? 'unknown',
                'update_method' => 'automatic',
            ]);
        }
        foreach ( [ 'plugin', 'theme' ] as $type ) {
            if ( ! empty( $results[$type] ) ) {
                foreach ( $results[$type] as $item_result ) {
                    self::log( 'system_auto_updated', [
                        'update_type'  => $type,
                        'item_name'    => $item_result->item->name ?? ( $item_result->item->slug ?? 'N/A' ),
                        'item_version' => $item_result->item->new_version ?? ( $item_result->item->version ?? 'N/A' ),
                        'old_version'  => $item_result->item->current_version ?? 'unknown',
                        'successful'   => $item_result->result !== false,
                    ]);
                }
            }
        }
    }

    public static function log_file_editor_saved() {
        $file = isset( $_POST['file'] ) ? sanitize_text_field( wp_unslash( $_POST['file'] ) ) : '';
        $plugin = isset( $_POST['plugin'] ) ? sanitize_text_field( wp_unslash( $_POST['plugin'] ) ) : '';
        $theme = isset( $_POST['theme'] ) ? sanitize_text_field( wp_unslash( $_POST['theme'] ) ) : '';
        $component_type = $plugin ? 'plugin' : ( $theme ? 'theme' : 'unknown' );
        $component_name = $plugin ?: $theme;
        if ( $file ) {
            self::log( 'file_editor_saved', [
                'file_path'      => $file,
                'component_type' => $component_type,
                'component_name' => $component_name,
            ]);
        }
    }

