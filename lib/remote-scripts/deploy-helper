    public static function log_after_delete_theme( $stylesheet, $deleted ) {
        if ( $deleted && isset( self::$deleted_theme_data[$stylesheet] ) ) {
            self::log( 'theme_deleted', [ 'theme' => self::$deleted_theme_data[$stylesheet] ] );
            self::$logged_deletes_this_request[$stylesheet] = true;
        }
        unset( self::$deleted_theme_data[$stylesheet] );
    }

