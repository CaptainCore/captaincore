/**
 * Class MagicLogin
 * Handles one-time login functionality and WP-CLI commands for login.
 */
class MagicLogin {

	/**
	 * Initializes hooks related to magic login.
	 */
	public static function init() {
		// Handle quick login early via wp_loaded to avoid interference from
		// other plugins' admin_init hooks (e.g. RankMath Pro background processing
		// calls check_ajax_referer() which kills unrelated AJAX requests).
		add_action( 'wp_loaded', [ __CLASS__, 'maybe_handle_quick_login' ], 0 );
		add_action( 'wp_ajax_nopriv_captaincore_quick_login', [ __CLASS__, 'quick_login_action_callback' ] );
		add_action( 'init', [ __CLASS__, 'login_handle_token' ] );

		if ( defined( 'WP_CLI' ) && WP_CLI ) {
			\WP_CLI::add_command( 'user login', [ __CLASS__, 'generate_login_link_command' ] );
		}
	}

	/**
	 * Handle quick login requests early (before admin_init) to prevent
	 * other plugins from interfering with the AJAX request.
	 */
	public static function maybe_handle_quick_login() {
		if ( ! defined( 'DOING_AJAX' ) || ! DOING_AJAX ) {
			return;
		}
		if ( empty( $_REQUEST['action'] ) || $_REQUEST['action'] !== 'captaincore_quick_login' ) {
			return;
		}
		self::quick_login_action_callback();
	}

	/**
	 * Verify an HMAC-signed request from CaptainCore.
	 * Expects JSON body with `token` (HMAC signature) and `timestamp`.
	 */
	private static function verify_request_token( $post ) {
		if ( ! isset( $post->token, $post->timestamp ) ) {
			return false;
		}
		$timestamp = (int) $post->timestamp;
		// Reject requests older than 30 seconds to prevent replay attacks.
		if ( abs( time() - $timestamp ) > 30 ) {
			return false;
		}
		$expected = hash_hmac( 'sha256', (string) $timestamp, md5( AUTH_KEY ) );
		return hash_equals( $expected, (string) $post->token );
	}

	/**
	 * Rate-limit AJAX login requests by IP. Returns true if throttled.
	 */
	private static function is_rate_limited() {
		$ip            = $_SERVER['REMOTE_ADDR'] ?? 'unknown';
		$transient_key = 'cc_login_limit_' . md5( $ip );
		$attempts      = (int) get_transient( $transient_key );
		if ( $attempts >= 5 ) {
			return true;
		}
		set_transient( $transient_key, $attempts + 1, MINUTE_IN_SECONDS );
		return false;
	}

	/**
	 * Generate a login token and store a hashed version with an expiration timestamp.
	 *
	 * @param int $user_id         The user ID.
	 * @param int $expires_in_secs Seconds until the token expires.
	 * @return string The raw token (for use in the login URL).
	 */
	private static function create_login_token( $user_id, $expires_in_secs ) {
		$raw_token = wp_generate_password( 48, false );
		update_user_meta( $user_id, 'captaincore_login_token', wp_hash( $raw_token ) );
		update_user_meta( $user_id, 'captaincore_login_token_expires', time() + $expires_in_secs );
		return $raw_token;
	}

	/**
	 * Registers AJAX callback for quick logins.
	 */
	public static function quick_login_action_callback() {
		if ( self::is_rate_limited() ) {
			wp_send_json_error( [ 'message' => 'Too many requests' ], 429 );
			wp_die();
		}

		$post = json_decode( file_get_contents( 'php://input' ) );

		if ( ! self::verify_request_token( $post ) ) {
			wp_send_json_error( [ 'message' => 'Invalid Token' ], 403 );
			wp_die();
		}

		$user_login = isset( $post->user_login ) ? sanitize_user( str_replace( '%20', ' ', $post->user_login ) ) : '';
		$user       = get_user_by( 'login', $user_login );

		if ( ! $user ) {
			wp_send_json_error( [ 'message' => 'User not found' ], 404 );
			wp_die();
		}

		$token = self::create_login_token( $user->ID, 10 * MINUTE_IN_SECONDS );

		$query_args = [
			'user_id'                 => $user->ID,
			'captaincore_login_token' => $token,
		];
		$login_url    = wp_login_url();
		$one_time_url = add_query_arg( $query_args, $login_url );

		echo esc_url_raw( $one_time_url );
		wp_die();
	}

	/**
	 * Login a request in as a user if the token is valid.
	 */
	public static function login_handle_token() {
		global $pagenow;

		if ( 'wp-login.php' !== $pagenow || empty( $_GET['user_id'] ) || empty( $_GET['captaincore_login_token'] ) ) {
			return;
		}

		$user_id = (int) $_GET['user_id'];
		$token   = sanitize_text_field( $_GET['captaincore_login_token'] );

		if ( is_user_logged_in() ) {
			$current_user_login = wp_get_current_user()->user_login;
			// translators: %1$s: current user login, %2$s: admin URL
			$error = sprintf( __( 'Invalid one-time login token, but you are logged in as \'%1$s\'. <a href="%2$s">Go to the dashboard instead</a>?', 'captaincore-helper' ), esc_html( $current_user_login ), esc_url( admin_url() ) );
		} else {
			// translators: %s: login URL
			$error = sprintf( __( 'Invalid one-time login token. <a href="%s">Try signing in instead</a>?', 'captaincore-helper' ), esc_url( wp_login_url() ) );
		}

		// Use a generic error message to ensure user ids can't be sniffed
		$user = get_user_by( 'id', $user_id );
		if ( ! $user ) {
			wp_die( wp_kses_post( $error ) );
		}

		$stored_hash = get_user_meta( $user->ID, 'captaincore_login_token', true );
		$expires_at  = (int) get_user_meta( $user->ID, 'captaincore_login_token_expires', true );

		// Always clean up token data before evaluating validity.
		delete_user_meta( $user->ID, 'captaincore_login_token' );
		delete_user_meta( $user->ID, 'captaincore_login_token_expires' );

		// Validate token: hash the incoming raw token and compare to stored hash.
		$is_valid = $stored_hash && hash_equals( (string) $stored_hash, wp_hash( $token ) );

		// Check expiration.
		if ( $is_valid && $expires_at && time() > $expires_at ) {
			$is_valid = false;
		}

		if ( ! $is_valid ) {
			wp_die( wp_kses_post( $error ) );
		}

		wp_set_auth_cookie( $user->ID, true );
		wp_safe_redirect( admin_url() );
		exit;
	}

	/**
	 * Generates a one-time login link for a user based on user ID, email, or login. (WP-CLI command)
	 *
	 * ## OPTIONS
	 *
	 * <user_identifier>
	 * : The user ID, email, or login of the user to generate the login link for.
	 *
	 * ## EXAMPLES
	 *
	 * wp user login 123
	 * wp user login user@example.com
	 * wp user login myusername
	 *
	 * @param array $args The command arguments.
	 */
	public static function generate_login_link_command( $args ) {
		$user_identifier = $args[0];

		// Determine if the identifier is a user ID, email, or login
		if ( is_numeric( $user_identifier ) ) {
			$user = get_user_by( 'ID', (int) $user_identifier );
		} elseif ( is_email( $user_identifier ) ) {
			$user = get_user_by( 'email', $user_identifier );
		} else {
			$user = get_user_by( 'login', $user_identifier );
		}

		// Check if the user exists
		if ( ! $user ) {
			\WP_CLI::error( "User not found: $user_identifier" );
			return;
		}

		// Generate token with 1 week expiration for WP-CLI links.
		$token = self::create_login_token( $user->ID, WEEK_IN_SECONDS );

		// Construct the one-time login URL
		$query_args = [
			'user_id'                 => $user->ID,
			'captaincore_login_token' => $token,
		];
		$login_url    = wp_login_url();
		$one_time_url = add_query_arg( $query_args, $login_url );

		// Output the URL to the CLI
		\WP_CLI::log( esc_url_raw( $one_time_url ) );
	}
}

/**
 * Class Helpers
 * Contains various helper functions and WordPress modifications.
 */
class Helpers {

	/**
	 * Initializes hooks for helper functions.
	 */
	public static function init() {
		add_action( 'wp_dashboard_setup', [ __CLASS__, 'remove_site_health_widget' ] );
		add_filter( 'auto_plugin_update_send_email', '__return_false' );
		add_filter( 'auto_theme_update_send_email', '__return_false' );
		add_filter( 'send_retrieve_password_email', [ __CLASS__, 'can_request_lost_password' ] );

		// CleanTalk clutter removal
		add_action( 'admin_menu', [ __CLASS__, 'modify_cleantalk_admin_menu' ], 20 );
		add_action( 'after_setup_theme', [ __CLASS__, 'remove_cleantalk_plugin_links_filter' ] );
		add_filter( 'all_plugins', [ __CLASS__, 'modify_cleantalk_plugin_name' ] );
		add_filter( 'plugin_row_meta', [ __CLASS__, 'modify_cleantalk_plugin_row_meta' ], 10, 2 );
	}

	/**
	 * Remove site health widget from dashboard.
	 */
	public static function remove_site_health_widget() {
		global $wp_meta_boxes;
		if ( isset( $wp_meta_boxes['dashboard']['normal']['core']['dashboard_site_health'] ) ) {
			unset( $wp_meta_boxes['dashboard']['normal']['core']['dashboard_site_health'] );
		}
	}

	/**
	 * Modifies CleanTalk admin menu item.
	 */
	public static function modify_cleantalk_admin_menu() {
		global $submenu;
		if ( empty( $submenu["options-general.php"] ) ) {
			return;
		}
		foreach ( $submenu["options-general.php"] as $key => $menu_item ) {
			if ( isset( $menu_item[0] ) && $menu_item[0] == 'Anti-Spam by CleanTalk' ) {
				$submenu["options-general.php"][ $key ][0] = 'CleanTalk';
				// Check if title attribute exists before modifying
				if ( isset( $submenu["options-general.php"][ $key ][3] ) ) {
				    $submenu["options-general.php"][ $key ][3] = 'CleanTalk';
				}
				break;
			}
		}
	}

	/**
	 * Removes CleanTalk plugin links filter.
	 */
	public static function remove_cleantalk_plugin_links_filter() {
		if ( function_exists( 'apbct_admin__register_plugin_links' ) ) {
			remove_filter( 'plugin_row_meta', 'apbct_admin__register_plugin_links', 10 );
		}
	}

	/**
	 * Modifies CleanTalk plugin name in the plugins list.
	 *
	 * @param array $plugins List of all plugins.
	 * @return array Modified list of plugins.
	 */
	public static function modify_cleantalk_plugin_name( $plugins ) {
		$plugin_file = 'cleantalk-spam-protect/cleantalk.php';
		// Check if the plugin exists in the list and modify the name
		if ( isset( $plugins[ $plugin_file ] ) ) {
			$plugins[ $plugin_file ]['Name'] = 'CleanTalk Anti-Spam';
		}
		return $plugins;
	}

	/**
	 * Modifies CleanTalk plugin row meta.
	 *
	 * @param array  $plugin_meta Array of plugin meta links.
	 * @param string $plugin_file Path to the plugin file.
	 * @return array Modified plugin meta links.
	 */
	public static function modify_cleantalk_plugin_row_meta( $plugin_meta, $plugin_file ) {
		$target_plugin = 'cleantalk-spam-protect/cleantalk.php';
		// Check if the plugin matches the one you want to modify
		if ( $plugin_file === $target_plugin ) {
			// Find the "By" field and replace it
			foreach ( $plugin_meta as &$meta ) {
				if ( strpos( $meta, 'СleanTalk - Anti-Spam Protection' ) !== false ) {
					$meta = str_replace( 'СleanTalk - Anti-Spam Protection', 'CleanTalk', $meta );
				}
			}
		}
		return $plugin_meta;
	}

	/**
	 * Determines if a lost password email can be sent based on IP address.
	 *
	 * Consults the blocklist file bundled alongside this mu-plugin
	 * (captaincore-ip-blocklist.php). The file contains both a manually
	 * maintained list and a geo-block list derived from IP2Location LITE.
	 *
	 * Client IP is resolved via CF-Connecting-IP → X-Forwarded-For → REMOTE_ADDR
	 * so Cloudflare-fronted sites don't just see the CF edge.
	 *
	 * @return bool True if email can be sent, false otherwise.
	 */
	public static function can_request_lost_password() {
		$ip = self::get_client_ip();
		if ( $ip === '' ) {
			return true; // Unknown IP — err on the side of letting legit users through.
		}
		return ! self::ip_in_blocklist( $ip );
	}

	/**
	 * Resolve the real client IP, preferring CF-Connecting-IP and X-Forwarded-For
	 * over REMOTE_ADDR (which is the Cloudflare edge on CF-fronted sites).
	 * Public so SecurityLogger can reuse the same resolution.
	 */
	public static function get_client_ip() {
		$candidates = [];
		if ( ! empty( $_SERVER['HTTP_CF_CONNECTING_IP'] ) ) {
			$candidates[] = $_SERVER['HTTP_CF_CONNECTING_IP'];
		}
		if ( ! empty( $_SERVER['HTTP_X_FORWARDED_FOR'] ) ) {
			$candidates[] = trim( explode( ',', $_SERVER['HTTP_X_FORWARDED_FOR'] )[0] );
		}
		if ( ! empty( $_SERVER['REMOTE_ADDR'] ) ) {
			$candidates[] = $_SERVER['REMOTE_ADDR'];
		}
		foreach ( $candidates as $c ) {
			$c = sanitize_text_field( wp_unslash( $c ) );
			if ( filter_var( $c, FILTER_VALIDATE_IP ) ) {
				return $c;
			}
		}
		return '';
	}

	private static $blocklist_cache = null;

	/**
	 * Load blocklist entries (bare IPs and CIDRs) from the bundled file.
	 * Parsed once per request and cached in a static property.
	 */
	private static function get_blocklist() {
		if ( self::$blocklist_cache !== null ) {
			return self::$blocklist_cache;
		}
		self::$blocklist_cache = [];
		$file = WPMU_PLUGIN_DIR . '/captaincore-ip-blocklist.php';
		if ( ! is_readable( $file ) ) {
			return self::$blocklist_cache;
		}
		$handle = @fopen( $file, 'r' );
		if ( ! $handle ) {
			return self::$blocklist_cache;
		}
		while ( ( $line = fgets( $handle ) ) !== false ) {
			$line = trim( preg_replace( '/#.*$/', '', $line ) );
			if ( $line === '' ) {
				continue;
			}
			// Skip the PHP guard line at the top.
			if ( strpos( $line, '<?php' ) === 0 || strpos( $line, '?>' ) !== false ) {
				continue;
			}
			self::$blocklist_cache[] = $line;
		}
		fclose( $handle );
		return self::$blocklist_cache;
	}

	/**
	 * Check if an IP matches any entry in the blocklist (bare IP or CIDR).
	 */
	private static function ip_in_blocklist( $ip ) {
		$is_v6 = strpos( $ip, ':' ) !== false;
		foreach ( self::get_blocklist() as $entry ) {
			if ( strpos( $entry, '/' ) === false ) {
				if ( strcasecmp( $entry, $ip ) === 0 ) {
					return true;
				}
				continue;
			}
			if ( self::ip_in_cidr( $ip, $entry, $is_v6 ) ) {
				return true;
			}
		}
		return false;
	}

	/**
	 * Test whether an IP falls inside a CIDR block. Supports v4 and v6.
	 */
	private static function ip_in_cidr( $ip, $cidr, $is_v6 ) {
		$parts = explode( '/', $cidr, 2 );
		if ( count( $parts ) !== 2 ) {
			return false;
		}
		$subnet = $parts[0];
		$bits   = (int) $parts[1];
		$subnet_is_v6 = strpos( $subnet, ':' ) !== false;
		if ( $is_v6 !== $subnet_is_v6 ) {
			return false; // Mismatched address families.
		}
		if ( $is_v6 ) {
			$ip_bin  = @inet_pton( $ip );
			$net_bin = @inet_pton( $subnet );
			if ( $ip_bin === false || $net_bin === false || strlen( $ip_bin ) !== 16 || strlen( $net_bin ) !== 16 ) {
				return false;
			}
			$bytes = intdiv( $bits, 8 );
			$rem   = $bits % 8;
			if ( $bytes > 0 && substr( $ip_bin, 0, $bytes ) !== substr( $net_bin, 0, $bytes ) ) {
				return false;
			}
			if ( $rem === 0 ) {
				return true;
			}
			$mask = chr( ( 0xff << ( 8 - $rem ) ) & 0xff );
			return ( $ip_bin[ $bytes ] & $mask ) === ( $net_bin[ $bytes ] & $mask );
		}
		// IPv4
		$ip_long  = ip2long( $ip );
		$net_long = ip2long( $subnet );
		if ( $ip_long === false || $net_long === false ) {
			return false;
		}
		if ( $bits <= 0 ) {
			return true;
		}
		if ( $bits >= 32 ) {
			return $ip_long === $net_long;
		}
		$mask = -1 << ( 32 - $bits );
		return ( $ip_long & $mask ) === ( $net_long & $mask );
	}
}

/**
 * Class TGMPAUpdater
 * Injects update functionality for TGMPA-managed plugins with external sources.
 */
class TGMPAUpdater {

	/**
	 * Constructor. Initializes hooks if TGMPA is active.
	 */
	public function __construct() {
		// Delay hook registration until wp_loaded to ensure TGM_Plugin_Activation class is available.
		add_action( 'wp_loaded', [ $this, 'register_hooks' ] );
	}

	/**
	 * Registers hooks if TGM Plugin Activation is active and has registered plugins.
	 */
	public function register_hooks() {
		if ( class_exists( '\TGM_Plugin_Activation' ) && method_exists( '\TGM_Plugin_Activation', 'get_instance' ) && has_action( 'tgmpa_register' ) ) {
			// Ensure TGMPA has had a chance to register its plugins before we try to access them.
			// The 'tgmpa_register' action itself might be too early for get_instance()->plugins to be populated.
			// A later action like 'init' with a high priority or 'wp_loaded' (as used in constructor) is safer.
			add_filter( 'plugins_api', [ $this, 'info' ], 20, 3 );
			add_filter( 'site_transient_update_plugins', [ $this, 'update' ] );
		}
	}

	/**
	 * Retrieves TGMPA plugins with external download sources.
	 *
	 * @return array Array of TGMPA plugins.
	 */
	private function get_tgmpa_plugins() {
		if ( ! class_exists( '\TGM_Plugin_Activation' ) ) {
			return [];
		}

		if ( ! method_exists( '\TGM_Plugin_Activation', 'get_instance' ) ) {
			return [];
		}

		// Ensure tgmpa_register has run to populate plugins.
		// This is crucial. If called too early, $tgmpa->plugins will be empty.
		do_action( 'tgmpa_register' );

		$tgmpa = \TGM_Plugin_Activation::get_instance();

		// It's possible populate_file_path() isn't called if TGMPA doesn't display notices.
		// We might need to call it manually if file_path is consistently missing.
		if ( method_exists( $tgmpa, 'populate_file_path' ) && empty(current(array_values($tgmpa->plugins))['file_path']) ) {
		    $tgmpa->populate_file_path();
		}


		if ( empty( $tgmpa->plugins ) ) {
			return [];
		}

		$external_plugins = [];
		foreach ( $tgmpa->plugins as $plugin_slug => $plugin_data ) {
			if ( isset( $plugin_data['source_type'] ) && $plugin_data['source_type'] === 'external' && !empty( $plugin_data['source'] ) ) {
				// Ensure file_path is set, if not, try to derive it or skip.
				if ( empty( $plugin_data['file_path'] ) ) {
					// Attempt to construct file_path if slug is conventional (plugin-name/plugin-main-file.php)
					// This is a fallback and might not always be correct.
					// A better solution is to ensure TGMPA configuration provides 'file_path'.
					if ( strpos( $plugin_slug, '/' ) === false ) {
						$plugin_data['file_path'] = $plugin_slug . '/' . $plugin_slug . '.php'; // Common convention
					} else {
						// If slug itself contains a path, it might be the file_path
						if ( substr( $plugin_slug, -4 ) === '.php' ) {
						    $plugin_data['file_path'] = $plugin_slug;
						} else {
						    // Cannot reliably determine file_path, skip this plugin for updates.
						    continue;
						}
					}
				}
				$external_plugins[ $plugin_slug ] = $plugin_data;
			}
		}
		return $external_plugins;
	}

	/**
	 * Provides plugin information for the WordPress updater.
	 *
	 * @param mixed  $response The response object or false.
	 * @param string $action   The type of information being requested.
	 * @param object $args     Arguments passed to the plugins_api function.
	 * @return mixed The response object or false.
	 */
	public function info( $response, $action, $args ) {
		// Do nothing if not getting plugin information or if response is already set by another handler.
		if ( 'plugin_information' !== $action || ! empty( $response ) ) {
			return $response;
		}

		if ( empty( $args->slug ) ) {
			return $response;
		}

		$tgmpa_plugins = $this->get_tgmpa_plugins();

		if ( empty( $tgmpa_plugins ) || ! isset( $tgmpa_plugins[ $args->slug ] ) ) {
			return $response;
		}

		$plugin = $tgmpa_plugins[ $args->slug ];

		$response                = new \stdClass();
		$response->name          = isset($plugin['name']) ? $plugin['name'] : $args->slug;
		$response->slug          = $args->slug;
		$response->version       = $plugin['version'];
		$response->download_link = $plugin['source'];
		$response->trunk         = $plugin['source']; // Typically the same as download_link for external sources

		// Optional fields:
		$response->author        = isset($plugin['author']) ? $plugin['author'] : 'Unknown';
		$response->requires      = isset($plugin['requires']) ? $plugin['requires'] : get_bloginfo( 'version' );
		$response->tested        = isset($plugin['tested']) ? $plugin['tested'] : get_bloginfo( 'version' );
		// $response->homepage      = isset($plugin['homepage']) ? $plugin['homepage'] : '';
		// $response->sections      = ['description' => isset($plugin['description']) ? $plugin['description'] : ''];

		return $response;
	}

	/**
	 * Checks for updates to TGMPA-managed plugins.
	 *
	 * @param object $transient The plugin update transient.
	 * @return object The modified plugin update transient.
	 */
	public function update( $transient ) {
		if ( empty( $transient->checked ) ) {
			return $transient;
		}

		$tgmpa_plugins     = $this->get_tgmpa_plugins();
		$installed_plugins = get_plugins();

		if ( empty( $tgmpa_plugins ) ) {
			return $transient;
		}

		foreach ( $tgmpa_plugins as $plugin_slug => $plugin_data ) {
			$plugin_file_path = $plugin_data['file_path'];

			// Skip if TGMPA plugin not installed or file_path is missing
			if ( ! isset( $installed_plugins[ $plugin_file_path ] ) ) {
				// Try to find by slug if file_path caused issues
				foreach ( $installed_plugins as $installed_file_path => $installed_data ) {
					if ( strpos( $installed_file_path, $plugin_slug . '/' ) === 0 ) {
						$plugin_file_path = $installed_file_path; // Found it
						break;
					}
				}
				// If still not found, continue
				if ( ! isset( $installed_plugins[ $plugin_file_path ] ) ) {
				    if ( defined( 'WP_CLI' ) && WP_CLI ) {
				        \WP_CLI::debug( "CaptainCore TGMPAUpdater: Plugin with slug '{$plugin_slug}' and expected path '{$plugin_data['file_path']}' not found among installed plugins.", 'captaincore' );
				    }
					continue;
				}
			}


			if ( version_compare( $installed_plugins[ $plugin_file_path ]['Version'], $plugin_data['version'], '<' ) ) {
				$response              = new \stdClass();
				$response->slug        = $plugin_slug;
				$response->plugin      = $plugin_file_path;
				$response->new_version = $plugin_data['version'];
				$response->package     = $plugin_data['source'];
				$response->url         = isset($plugin_data['url']) ? $plugin_data['url'] : ''; // Optional: link to plugin homepage

				$transient->response[ $plugin_file_path ] = $response;
			}
		}

		return $transient;
	}
}

