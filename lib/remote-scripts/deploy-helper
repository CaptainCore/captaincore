    private static function get_table_name() {
        global $wpdb;
        return $wpdb->prefix . 'captaincore_security_log';
    }

    public static function ensure_table_exists_public() { self::ensure_table_exists(); }

    public static function log_public( $action, array $data = [], $user_id = null ) {
        self::log( $action, $data, $user_id );
    }

    private static function ensure_table_exists() {
        if ( self::$table_checked ) { return; }
        global $wpdb;
        $table_name = self::get_table_name();
        $charset_collate = $wpdb->get_charset_collate();
        $table_exists = $wpdb->get_var( $wpdb->prepare( "SELECT COUNT(*) FROM information_schema.TABLES WHERE TABLE_SCHEMA = %s AND TABLE_NAME = %s", DB_NAME, $table_name ) );
        if ( ! $table_exists ) {
            if ( ! function_exists( 'dbDelta' ) ) { require_once ABSPATH . 'wp-admin/includes/upgrade.php'; }
            $sql = "CREATE TABLE $table_name (
                log_id BIGINT(20) UNSIGNED NOT NULL AUTO_INCREMENT,
                log_time DATETIME NOT NULL,
                action VARCHAR(100) NOT NULL,
                user_type VARCHAR(30) NULL,
                user_id BIGINT(20) UNSIGNED NULL,
                user_login VARCHAR(60) NULL,
                ip_address VARCHAR(100) NULL,
                log_data LONGTEXT NULL,
                PRIMARY KEY  (log_id),
                INDEX idx_log_time (log_time),
                INDEX idx_action (action)
            ) $charset_collate;";
            dbDelta( $sql );
        }
        self::$table_checked = true;
    }

    private static function log( $action, $data = [], $user_id = null ) {
        global $wpdb;
        self::ensure_table_exists();
        if ( ! self::$table_checked ) { return; }

        $user_type = null;
        $log_user_id = null;
        $log_user_login = null;
        $ip_address = null;

        if ( defined( 'WP_CLI' ) && WP_CLI ) {
            $user_type = 'wp_cli';
        } else {
            $current_user = null;
            if ( $user_id !== null ) {
                $current_user = get_userdata( $user_id );
            } elseif ( function_exists( 'wp_get_current_user' ) ) {
                $current_user = wp_get_current_user();
            }

            if ( $current_user && $current_user->ID > 0 ) {
                $user_type = 'wp_user';
                $log_user_id = $current_user->ID;
                $log_user_login = $current_user->user_login;
            } else {
                $user_type = 'system_or_anonymous';
            }

            // Resolve real client IP via CF-Connecting-IP → X-Forwarded-For → REMOTE_ADDR
            // so CF-fronted sites don't record the CF edge.
            $resolved = Helpers::get_client_ip();
            $ip_address = $resolved !== '' ? $resolved : null;
        }

        $table_name = self::get_table_name();
        $wpdb->insert( $table_name, [
            'log_time'   => current_time( 'mysql', true ),
            'action'     => $action,
            'user_type'  => $user_type,
            'user_id'    => $log_user_id ? (int) $log_user_id : null,
            'user_login' => $log_user_login,
            'ip_address' => $ip_address,
            'log_data'   => json_encode( $data, JSON_UNESCAPED_SLASHES | JSON_PARTIAL_OUTPUT_ON_ERROR ),
        ]);
    }

    private static function get_plugin_details( $plugin_file ) {
        if ( ! function_exists( 'get_plugin_data' ) ) {
            require_once ABSPATH . 'wp-admin/includes/plugin.php';
        }
        $plugin_path = WP_PLUGIN_DIR . '/' . $plugin_file;
        if ( ! file_exists( $plugin_path ) ) {
            return self::$deleted_plugin_data[$plugin_file] ?? null;
        }
        $plugin_data = get_plugin_data( $plugin_path, false, false );
        if ( empty( $plugin_data['Name'] ) ) { return null; }
        return [
            'name'       => $plugin_data['Name'],
            'version'    => $plugin_data['Version'],
            'plugin_uri' => $plugin_data['PluginURI'] ?? '',
            'author'     => $plugin_data['Author'] ?? '',
            'file_path'  => $plugin_file,
        ];
    }

    private static function get_theme_details( $stylesheet ) {
        $theme = wp_get_theme( $stylesheet );
        if ( ! $theme->exists() ) {
            return self::$deleted_theme_data[$stylesheet] ?? null;
        }
        return [
            'name'       => $theme->get( 'Name' ),
            'version'    => $theme->get( 'Version' ),
            'theme_uri'  => $theme->get( 'ThemeURI' ),
            'author'     => $theme->get( 'Author' ),
            'stylesheet' => $stylesheet,
            'template'   => $theme->get_template(),
        ];
    }

    private static function is_tracked_option( $option_name ) {
        return in_array( $option_name, self::$tracked_options, true );
    }

    private static function truncate_value( $value, $length = 200 ) {
        if ( is_string( $value ) ) { return mb_strimwidth( $value, 0, $length, '...' ); }
        if ( is_scalar( $value ) ) { return $value; }
        if ( is_array( $value ) || is_object( $value ) ) {
            $json = json_encode( $value, JSON_UNESCAPED_SLASHES | JSON_PARTIAL_OUTPUT_ON_ERROR );
            return mb_strimwidth( $json, 0, $length, '...' );
        }
        return '(' . gettype( $value ) . ')';
    }

    // --- User lifecycle handlers ---

    public static function log_user_register( $user_id ) {
        $user = get_userdata( $user_id );
        if ( $user ) {
            self::log( 'user_registered', [
                'user_id'    => $user_id,
                'user_login' => $user->user_login,
                'user_email' => $user->user_email,
                'user_roles' => $user->roles,
            ]);
        }
    }

    public static function log_delete_user( $user_id ) {
        $user = get_userdata( $user_id );
        $reassign_id = isset( $_POST['reassign_user'] ) ? (int) $_POST['reassign_user'] : null;
        self::log( 'user_deleted', [
            'deleted_user_id'       => $user_id,
            'deleted_user_login'    => $user ? $user->user_login : '(unknown)',
            'deleted_user_roles'    => $user ? $user->roles : [],
            'reassigned_to_user_id' => $reassign_id,
        ]);
    }

    public static function log_user_role_changed( $user_id, $new_role, $old_roles ) {
        $user = get_userdata( $user_id );
        if ( ! $user ) { return; }
        $new_roles = $user->roles;
        $old_roles_array = is_array( $old_roles ) ? $old_roles : (array) $old_roles;
        sort( $old_roles_array );
        sort( $new_roles );
        if ( $old_roles_array !== $new_roles ) {
            self::log( 'user_role_changed', [
                'target_user_id'    => $user_id,
                'target_user_login' => $user->user_login,
                'old_roles'         => $old_roles_array,
                'new_roles'         => $new_roles,
            ]);
        }
    }

    public static function capture_old_super_admins() {
        if ( is_multisite() && self::$old_superadmins === null ) {
            self::$old_superadmins = get_super_admins();
        }
    }

    public static function log_super_admin_granted( $user_id ) {
        $user = get_userdata( $user_id );
        if ( $user && is_array( self::$old_superadmins ) && ! in_array( $user->user_login, self::$old_superadmins, true ) ) {
            self::log( 'user_super_admin_granted', [ 'target_user_id' => $user_id, 'target_user_login' => $user->user_login ] );
        }
        self::$old_superadmins = null;
    }

    public static function log_super_admin_revoked( $user_id ) {
        $user = get_userdata( $user_id );
        if ( $user && is_array( self::$old_superadmins ) && in_array( $user->user_login, self::$old_superadmins, true ) ) {
            self::log( 'user_super_admin_revoked', [ 'target_user_id' => $user_id, 'target_user_login' => $user->user_login ] );
        }
        self::$old_superadmins = null;
    }

    public static function log_password_changed_via_profile( $user_id, $old_user_data, $userdata = null ) {
        $new_user = get_userdata( $user_id );
        if ( ! $new_user || ! $old_user_data ) { return; }
        if ( $old_user_data->user_pass === $new_user->user_pass ) { return; }
        self::log( 'user_password_changed', [
            'target_user_id'    => $user_id,
            'target_user_login' => $new_user->user_login,
            'method'            => 'profile_update',
        ]);
    }

    public static function log_password_reset( $user, $new_pass ) {
        if ( ! $user || ! isset( $user->ID ) ) { return; }
        self::log( 'user_password_changed', [
            'target_user_id'    => $user->ID,
            'target_user_login' => $user->user_login,
            'method'            => 'password_reset',
        ]);
    }

    /**
     * Fires on every POST to /wp-login.php?action=lostpassword. Captures what the
     * requester submitted (username vs email), whether it resolved to an existing
     * account, and the real client IP. Does not indicate a successful reset; pair
     * with `user_password_changed` (method=password_reset) to see completed ones.
     */
    public static function log_password_reset_requested( $errors, $user_data = null ) {
        $raw = isset( $_POST['user_login'] ) ? trim( wp_unslash( $_POST['user_login'] ) ) : '';
        if ( $raw === '' ) { return; }
        $data = [
            'submitted'  => $raw,
            'kind'       => is_email( $raw ) ? 'email' : 'username',
            'user_found' => $user_data instanceof \WP_User,
        ];
        if ( $user_data instanceof \WP_User ) {
            $data['target_user_id']    = $user_data->ID;
            $data['target_user_login'] = $user_data->user_login;
        }
        self::log( 'password_reset_requested', $data );
    }

    // --- Plugin & theme lifecycle handlers ---

    public static function log_admin_init() {
        if ( self::$initial_plugins === null ) {
            if ( ! function_exists( 'get_plugins' ) ) { require_once ABSPATH . 'wp-admin/includes/plugin.php'; }
            self::$initial_plugins = get_plugins();
        }
        if ( empty( self::$initial_themes_data ) && ! ( defined( 'WP_CLI' ) && WP_CLI ) ) {
            if ( ! function_exists( 'wp_get_themes' ) ) { require_once ABSPATH . 'wp-includes/theme.php'; }
            $themes = wp_get_themes();
            if ( is_array( $themes ) ) {
                foreach ( $themes as $stylesheet => $theme_obj ) {
                    if ( $theme_obj instanceof \WP_Theme ) {
                        self::$initial_themes_data[$stylesheet] = [
                            'Name'    => $theme_obj->get( 'Name' ),
                            'Version' => $theme_obj->get( 'Version' ),
                        ];
                    }
                }
            }
        }
        if ( is_multisite() && self::$old_superadmins === null ) {
            self::$old_superadmins = get_super_admins();
        }
    }

    public static function log_plugin_activated( $plugin_file ) {
        $details = self::get_plugin_details( $plugin_file );
        if ( $details ) { self::log( 'plugin_activated', [ 'plugin' => $details ] ); }
    }

    public static function log_plugin_deactivated( $plugin_file ) {
        $details = self::get_plugin_details( $plugin_file );
        if ( $details ) { self::log( 'plugin_deactivated', [ 'plugin' => $details ] ); }
    }

    public static function log_upgrader_process_complete( $upgrader_object, $options ) {
        $type   = $options['type'] ?? null;
        $action = $options['action'] ?? null;

        if ( 'plugin' === $type ) {
            $plugins_to_process = [];
            if ( isset( $options['plugins'] ) && is_array( $options['plugins'] ) ) {
                $plugins_to_process = $options['plugins'];
            } elseif ( isset( $options['plugin'] ) && is_string( $options['plugin'] ) ) {
                $plugins_to_process = [ $options['plugin'] ];
            }
            if ( 'install' === $action && empty( $plugins_to_process ) && isset( $upgrader_object->result['destination_name'] ) ) {
                $plugin_slug = $upgrader_object->result['destination_name'];
                if ( ! function_exists( 'get_plugins' ) ) { require_once ABSPATH . 'wp-admin/includes/plugin.php'; }
                $_found = get_plugins( '/' . $plugin_slug );
                if ( ! empty( $_found ) ) { $plugins_to_process = [ array_key_first( $_found ) ]; }
            }
            if ( empty( $plugins_to_process ) ) { return; }

            foreach ( $plugins_to_process as $plugin_file ) {
                $details = self::get_plugin_details( $plugin_file );
                if ( 'install' === $action ) {
                    if ( isset( self::$logged_installs_this_request[$plugin_file] ) ) { continue; }
                    $log_data = $details
                        ? [ 'plugin' => $details ]
                        : [ 'plugin' => [ 'name' => $upgrader_object->new_plugin_data['Name'] ?? basename( dirname( $plugin_file ) ), 'version' => $upgrader_object->new_plugin_data['Version'] ?? 'N/A', 'file_path' => $plugin_file ] ];
                    self::log( 'plugin_installed', $log_data );
                    self::$logged_installs_this_request[$plugin_file] = true;
                } elseif ( 'update' === $action && $details ) {
                    $old_version = self::$initial_plugins[$plugin_file]['Version'] ?? 'unknown';
                    self::log( 'plugin_updated', [ 'plugin' => $details, 'old_version' => $old_version, 'new_version' => $details['version'] ] );
                }
            }
            if ( ! function_exists( 'get_plugins' ) ) { require_once ABSPATH . 'wp-admin/includes/plugin.php'; }
            self::$initial_plugins = get_plugins();

        } elseif ( 'theme' === $type ) {
            $themes_to_process = [];
            if ( isset( $options['themes'] ) && is_array( $options['themes'] ) ) {
                $themes_to_process = $options['themes'];
            } elseif ( isset( $options['theme'] ) && is_string( $options['theme'] ) ) {
                $themes_to_process = [ $options['theme'] ];
            }
            if ( empty( $themes_to_process ) ) { return; }

            foreach ( $themes_to_process as $stylesheet ) {
                $details = self::get_theme_details( $stylesheet );
                if ( ! $details ) { continue; }
                if ( 'install' === $action ) {
                    self::log( 'theme_installed', [ 'theme' => $details ] );
                } elseif ( 'update' === $action ) {
                    $old_version = self::$initial_themes_data[$stylesheet]['Version'] ?? 'unknown';
                    self::log( 'theme_updated', [ 'theme' => $details, 'old_version' => $old_version, 'new_version' => $details['version'] ] );
                }
            }
            self::refresh_theme_snapshot();
        }
    }

    public static function log_plugin_installed_via_install_actions( $actions, $api, $plugin_file, $install_result = null ) {
        if ( ( $install_result === null || ! is_wp_error( $install_result ) ) && ! empty( $plugin_file ) ) {
            if ( isset( self::$logged_installs_this_request[$plugin_file] ) ) { return $actions; }
            $details = self::get_plugin_details( $plugin_file );
            $log_data = $details
                ? [ 'plugin' => $details ]
                : [ 'plugin' => [ 'name' => $plugin_file, 'version' => 'N/A', 'file_path' => $plugin_file ] ];
            self::log( 'plugin_installed', $log_data );
            self::$logged_installs_this_request[$plugin_file] = true;
        }
        return $actions;
    }

    public static function log_before_delete_plugin( $plugin_file ) {
        $details = self::get_plugin_details( $plugin_file );
        if ( $details ) { self::$deleted_plugin_data[$plugin_file] = $details; }
        if ( ! function_exists( 'get_plugins' ) ) { require_once ABSPATH . 'wp-admin/includes/plugin.php'; }
        self::$initial_plugins = get_plugins();
    }

    public static function log_after_delete_plugin( $plugin_file, $deleted ) {
        if ( $deleted && isset( self::$deleted_plugin_data[$plugin_file] ) ) {
            self::log( 'plugin_deleted', [ 'plugin' => self::$deleted_plugin_data[$plugin_file] ] );
            self::$logged_deletes_this_request[$plugin_file] = true;
        }
        unset( self::$deleted_plugin_data[$plugin_file] );
        if ( ! function_exists( 'get_plugins' ) ) { require_once ABSPATH . 'wp-admin/includes/plugin.php'; }
        self::$initial_plugins = get_plugins();
    }

    public static function log_theme_activated( $theme_name ) {
        $activated_theme = wp_get_theme();
        if ( $activated_theme->exists() && $activated_theme->get( 'Name' ) === $theme_name ) {
            $details = self::get_theme_details( $activated_theme->get_stylesheet() );
            if ( $details ) { self::log( 'theme_activated', [ 'theme' => $details ] ); }
        }
    }

    public static function log_before_delete_theme( $stylesheet ) {
        $details = self::get_theme_details( $stylesheet );
        if ( $details ) { self::$deleted_theme_data[$stylesheet] = $details; }
