#!/usr/bin/env bash

#
#   Fetches total error log size in bytes
#

# Loop through arguments and separate regular arguments from flags
for arg in "$@"; do

  # Add to arguments array. (Does not starts with "--")
  if [[ $arg != --* ]]; then
    count=1+${#arguments[*]}
    arguments[$count]=$arg
    continue
  fi

  # Remove leading "--"
  flag_name=$( echo $arg | cut -c 3- )

  # Add to flags array
  count=1+${#flags[*]}
  flags[$count]=$arg

  # Process flags without data (Assign to variable)
  if [[ $arg != *"="* ]]; then
    flag_name=${flag_name//-/_}
    declare "$flag_name"=true
  fi

  # Process flags with data (Assign to variable)
  if [[ $arg == *"="* ]]; then
    flag_value=$( echo $flag_name | perl -n -e '/.+?=(.+)/&& print $1' ) # extract value
    flag_name=$( echo $flag_name | perl -n -e '/(.+?)=.+/&& print $1' ) # extract name
    flag_name=${flag_name/-/_}

    # Remove first and last quote if found
    flag_value="${flag_value%\"}"
    flag_value="${flag_value#\"}"

    declare "$flag_name"="$flag_value"
    continue
  fi

done

home_path=$(wp eval "echo get_home_path();" --skip-themes --skip-plugins 2>/dev/null)
parent_path=$(dirname "$home_path")
wp_content=$(wp eval "echo defined('WP_CONTENT_DIR') ? WP_CONTENT_DIR : get_home_path() . 'wp-content';" --skip-themes --skip-plugins 2>/dev/null)

total_size=0

# ~/logs/error.log*
for file in "$parent_path"/logs/*error.log*; do
    if [[ -f "$file" && ! "$file" == *.gz ]]; then
        size=$(stat -c%s "$file" 2>/dev/null || stat -f%z "$file" 2>/dev/null)
        total_size=$((total_size + size))
    fi
done

# error_log in home directory
if [[ -f "${home_path}error_log" ]]; then
    size=$(stat -c%s "${home_path}error_log" 2>/dev/null || stat -f%z "${home_path}error_log" 2>/dev/null)
    total_size=$((total_size + size))
fi

# wp-content/debug.log
if [[ -f "${wp_content}/debug.log" ]]; then
    size=$(stat -c%s "${wp_content}/debug.log" 2>/dev/null || stat -f%z "${wp_content}/debug.log" 2>/dev/null)
    total_size=$((total_size + size))
fi

if [[ "$human_readable" == "true" ]]; then
    if (( total_size >= 1073741824 )); then
        echo "$(awk "BEGIN {printf \"%.1f\", $total_size/1073741824}")G"
    elif (( total_size >= 1048576 )); then
        echo "$(awk "BEGIN {printf \"%.1f\", $total_size/1048576}")M"
    elif (( total_size >= 1024 )); then
        echo "$(awk "BEGIN {printf \"%.1f\", $total_size/1024}")K"
    else
        echo "${total_size}B"
    fi
else
    echo $total_size
fi
