    // --- WP-CLI capture and lifecycle handlers ---

    public static function cli_capture_initial_state() {
        try {
            if ( ! function_exists( 'get_plugins' ) ) { require_once ABSPATH . 'wp-admin/includes/plugin.php'; }
            self::$initial_plugins = get_plugins();
            if ( ! function_exists( 'wp_get_themes' ) ) { require_once ABSPATH . 'wp-includes/theme.php'; }
            $themes = wp_get_themes();
            self::$initial_themes_data = [];
            if ( is_array( $themes ) ) {
                foreach ( $themes as $stylesheet => $theme_obj ) {
                    if ( $theme_obj instanceof \WP_Theme ) {
                        self::$initial_themes_data[$stylesheet] = [
                            'Name'    => $theme_obj->get( 'Name' ),
                            'Version' => $theme_obj->get( 'Version' ),
                        ];
                    }
                }
            }
        } catch ( \Throwable $e ) {
            // Never block WP-CLI commands if SecurityLogger fails
        }
    }

    public static function cli_log_plugin_install_actions() {
        try {
            if ( ! function_exists( 'get_plugins' ) ) { require_once ABSPATH . 'wp-admin/includes/plugin.php'; }
            $current_plugins = get_plugins();
            $initial = self::$initial_plugins ?? [];
            if ( ! is_array( $initial ) ) { $initial = []; }
            $installed = array_diff_key( $current_plugins, $initial );
            foreach ( array_keys( $installed ) as $plugin_file ) {
                if ( isset( self::$logged_installs_this_request[$plugin_file] ) ) { continue; }
                $details = self::get_plugin_details( $plugin_file );
                self::log( 'plugin_installed', [
                    'plugin'  => $details ?: [ 'name' => $plugin_file, 'version' => 'N/A', 'file_path' => $plugin_file ],
                    'context' => 'wp_cli',
                ]);
                self::$logged_installs_this_request[$plugin_file] = true;
            }
            self::$initial_plugins = $current_plugins;
        } catch ( \Throwable $e ) {}
    }

    public static function cli_log_plugin_delete_actions() {
        try {
            $initial = self::$initial_plugins ?? [];
            if ( empty( $initial ) ) {
                if ( ! function_exists( 'get_plugins' ) ) { require_once ABSPATH . 'wp-admin/includes/plugin.php'; }
                $initial = get_plugins();
            }
            if ( function_exists( 'wp_clean_plugins_cache' ) ) { wp_clean_plugins_cache( true ); }
            if ( ! function_exists( 'get_plugins' ) ) { require_once ABSPATH . 'wp-admin/includes/plugin.php'; }
            $current_plugins = get_plugins();
            if ( ! is_array( $initial ) ) { $initial = []; }

            $deleted = array_diff_key( $initial, $current_plugins );
            $logged_by_diff = false;
            foreach ( $deleted as $plugin_file => $plugin_data ) {
                if ( isset( self::$logged_deletes_this_request[$plugin_file] ) ) { continue; }
                self::log( 'plugin_deleted', [
                    'plugin'  => [ 'name' => $plugin_data['Name'] ?? basename( dirname( $plugin_file ) ), 'version' => $plugin_data['Version'] ?? 'N/A', 'file_path' => $plugin_file ],
                    'context' => 'wp_cli',
                ]);
                unset( self::$deleted_plugin_data[$plugin_file] );
                $logged_by_diff = true;
            }

            if ( ! $logged_by_diff && ! empty( $initial ) ) {
                foreach ( $initial as $plugin_file => $initial_data ) {
                    if ( isset( $deleted[$plugin_file] ) ) { continue; }
                    if ( isset( self::$logged_deletes_this_request[$plugin_file] ) ) { continue; }
                    $plugin_path = WP_PLUGIN_DIR . '/' . $plugin_file;
                    if ( ! isset( $current_plugins[$plugin_file] ) && ! file_exists( $plugin_path ) ) {
                        self::log( 'plugin_deleted', [
                            'plugin'  => [ 'name' => $initial_data['Name'] ?? basename( dirname( $plugin_file ) ), 'version' => $initial_data['Version'] ?? 'N/A', 'file_path' => $plugin_file ],
                            'context' => 'wp_cli_fs_check',
                        ]);
                        unset( self::$deleted_plugin_data[$plugin_file] );
                    }
                }
            }
            self::$initial_plugins = $current_plugins;
        } catch ( \Throwable $e ) {}
    }

    public static function cli_log_plugin_update_actions() {
        try {
            if ( ! function_exists( 'get_plugins' ) ) { require_once ABSPATH . 'wp-admin/includes/plugin.php'; }
            $current_plugins = get_plugins();
            $initial = self::$initial_plugins ?? [];
            if ( ! is_array( $initial ) ) { $initial = []; }
            foreach ( $current_plugins as $plugin_file => $new_data ) {
                if ( isset( $initial[$plugin_file] ) && version_compare( $initial[$plugin_file]['Version'], $new_data['Version'], '!=' ) ) {
                    $details = self::get_plugin_details( $plugin_file );
                    if ( $details ) {
                        self::log( 'plugin_updated', [
                            'plugin'      => $details,
                            'old_version' => $initial[$plugin_file]['Version'],
                            'new_version' => $new_data['Version'],
                            'context'     => 'wp_cli',
                        ]);
                    }
                }
            }
            self::$initial_plugins = $current_plugins;
        } catch ( \Throwable $e ) {}
    }

    public static function cli_log_theme_install_actions() {
        try {
            if ( function_exists( 'wp_clean_themes_cache' ) ) { wp_clean_themes_cache( true ); }
            if ( ! function_exists( 'wp_get_themes' ) ) { require_once ABSPATH . 'wp-includes/theme.php'; }
            $current = wp_get_themes();
            $initial = self::$initial_themes_data ?? [];
            if ( ! is_array( $initial ) ) { $initial = []; }
            $installed = array_diff_key( $current, $initial );
            foreach ( array_keys( $installed ) as $stylesheet ) {
                $details = self::get_theme_details( $stylesheet );
                self::log( 'theme_installed', [
                    'theme'   => $details ?: [ 'name' => $stylesheet, 'version' => 'N/A', 'stylesheet' => $stylesheet ],
                    'context' => 'wp_cli',
                ]);
            }
            self::refresh_theme_snapshot( $current );
        } catch ( \Throwable $e ) {}
    }

    public static function cli_log_theme_delete_actions() {
        try {
            $initial = self::$initial_themes_data ?? [];
            if ( empty( $initial ) ) {
                if ( ! function_exists( 'wp_get_themes' ) ) { require_once ABSPATH . 'wp-includes/theme.php'; }
                $themes_now = wp_get_themes();
                if ( is_array( $themes_now ) ) {
                    foreach ( $themes_now as $stylesheet => $theme_obj ) {
                        if ( $theme_obj instanceof \WP_Theme ) {
                            $initial[$stylesheet] = [ 'Name' => $theme_obj->get( 'Name' ), 'Version' => $theme_obj->get( 'Version' ) ];
                        }
                    }
                }
            }
            if ( function_exists( 'wp_clean_themes_cache' ) ) { wp_clean_themes_cache( true ); }
            if ( ! function_exists( 'wp_get_themes' ) ) { require_once ABSPATH . 'wp-includes/theme.php'; }
            $current = wp_get_themes();
            if ( ! is_array( $initial ) ) { $initial = []; }

            $deleted = array_diff_key( $initial, $current );
            $logged_by_diff = false;
            foreach ( $deleted as $stylesheet => $theme_data ) {
                if ( isset( self::$logged_deletes_this_request[$stylesheet] ) ) { continue; }
                self::log( 'theme_deleted', [
                    'theme'   => [ 'name' => $theme_data['Name'] ?? $stylesheet, 'version' => $theme_data['Version'] ?? 'N/A', 'stylesheet' => $stylesheet ],
                    'context' => 'wp_cli',
                ]);
                unset( self::$deleted_theme_data[$stylesheet] );
                $logged_by_diff = true;
            }

            if ( ! $logged_by_diff && ! empty( $initial ) ) {
                $theme_root = get_theme_root();
                foreach ( $initial as $stylesheet => $theme_data ) {
                    if ( isset( $deleted[$stylesheet] ) ) { continue; }
                    if ( isset( self::$logged_deletes_this_request[$stylesheet] ) ) { continue; }
                    if ( ! isset( $current[$stylesheet] ) && ! is_dir( $theme_root . '/' . $stylesheet ) ) {
                        self::log( 'theme_deleted', [
                            'theme'   => [ 'name' => $theme_data['Name'] ?? $stylesheet, 'version' => $theme_data['Version'] ?? 'N/A', 'stylesheet' => $stylesheet ],
                            'context' => 'wp_cli_fs_check',
                        ]);
                        unset( self::$deleted_theme_data[$stylesheet] );
                    }
            }
        }
            self::refresh_theme_snapshot( $current );
        } catch ( \Throwable $e ) {}
    }

    public static function cli_log_theme_update_actions() {
        try {
            if ( function_exists( 'wp_clean_themes_cache' ) ) { wp_clean_themes_cache( true ); }
            if ( ! function_exists( 'wp_get_themes' ) ) { require_once ABSPATH . 'wp-includes/theme.php'; }
            $current = wp_get_themes();
            $initial = self::$initial_themes_data ?? [];
            if ( ! is_array( $initial ) ) { $initial = []; }
            foreach ( $current as $stylesheet => $theme_obj ) {
                if ( isset( $initial[$stylesheet] ) && $theme_obj instanceof \WP_Theme ) {
                    $old_version = $initial[$stylesheet]['Version'];
                    $new_version = $theme_obj->get( 'Version' );
                    if ( version_compare( $old_version, $new_version, '!=' ) ) {
                        $details = self::get_theme_details( $stylesheet );
                        if ( $details ) {
                            self::log( 'theme_updated', [
                                'theme'       => $details,
                                'old_version' => $old_version,
                                'new_version' => $new_version,
                                'context'     => 'wp_cli',
                            ]);
                        }
                    }
                }
            }
            self::refresh_theme_snapshot( $current );
        } catch ( \Throwable $e ) {}
    }

    private static function refresh_theme_snapshot( $themes_objs = null ) {
        if ( $themes_objs === null ) {
            if ( ! function_exists( 'wp_get_themes' ) ) { require_once ABSPATH . 'wp-includes/theme.php'; }
            $themes_objs = wp_get_themes();
        }
        $snapshot = [];
        if ( is_array( $themes_objs ) ) {
            foreach ( $themes_objs as $stylesheet => $theme_obj ) {
                if ( $theme_obj instanceof \WP_Theme ) {
                    $snapshot[$stylesheet] = [ 'Name' => $theme_obj->get( 'Name' ), 'Version' => $theme_obj->get( 'Version' ) ];
                }
            }
        }
        self::$initial_themes_data = $snapshot;
    }

    // --- WP-CLI commands ---

    public static function cli_list_logs( $args, $assoc_args ) {
        global $wpdb;
        self::ensure_table_exists();
        $table_name = self::get_table_name();
        $limit  = isset( $assoc_args['limit'] ) && is_numeric( $assoc_args['limit'] ) && $assoc_args['limit'] > 0 ? (int) $assoc_args['limit'] : 25;
        $offset = isset( $assoc_args['offset'] ) && is_numeric( $assoc_args['offset'] ) && $assoc_args['offset'] >= 0 ? (int) $assoc_args['offset'] : 0;

        $logs = $wpdb->get_results( $wpdb->prepare(
            "SELECT log_id, log_time, action, user_type, user_id, user_login, ip_address, log_data FROM $table_name ORDER BY log_id DESC LIMIT %d OFFSET %d",
            $limit, $offset
        ));

        if ( empty( $logs ) ) {
            \WP_CLI::log( $offset > 0 ? 'No more security logs at this offset.' : 'No security logs found.' );
            return;
        }

        $table_data = [];
        foreach ( $logs as $log ) {
            $data = json_decode( $log->log_data, true ) ?: [];
            $table_data[] = [
                'ID'      => $log->log_id,
                'Time'    => $log->log_time,
                'Action'  => $log->action,
                'User'    => $log->user_login ?: ( $log->user_type ?: 'N/A' ),
                'IP'      => $log->ip_address ?: 'N/A',
                'Details' => mb_strimwidth( self::generate_summary( $log->action, $data ), 0, 80, '...' ),
            ];
        }
        \WP_CLI\Utils\format_items( 'table', $table_data, [ 'ID', 'Time', 'Action', 'User', 'IP', 'Details' ] );
        \WP_CLI::log( "\nShowing " . ( $offset + 1 ) . ' to ' . ( $offset + count( $logs ) ) . '. Use --limit=N --offset=N to paginate.' );
        \WP_CLI::log( "Use 'wp captaincore security-log get <ID>' for full details." );
    }

    public static function cli_get_log( $args, $assoc_args ) {
        global $wpdb;
        if ( empty( $args[0] ) || ! is_numeric( $args[0] ) ) {
            \WP_CLI::error( 'Provide a numeric log ID. Usage: wp captaincore security-log get <id>' );
            return;
        }
        self::ensure_table_exists();
        $table_name = self::get_table_name();
        $log = $wpdb->get_row( $wpdb->prepare( "SELECT * FROM $table_name WHERE log_id = %d", (int) $args[0] ) );
        if ( ! $log ) {
            \WP_CLI::error( "Log entry #{$args[0]} not found." );
            return;
        }

        \WP_CLI::log( \WP_CLI::colorize( "%YSecurity Log #{$log->log_id}%n" ) );
        \WP_CLI::log( '-----------------------------' );
        \WP_CLI::log( 'Time:       ' . $log->log_time );
        \WP_CLI::log( 'Action:     ' . $log->action );
        \WP_CLI::log( 'User Type:  ' . ( $log->user_type ?: 'N/A' ) );
        if ( $log->user_id ) { \WP_CLI::log( 'User ID:    ' . $log->user_id ); }
        if ( $log->user_login ) { \WP_CLI::log( 'User Login: ' . $log->user_login ); }
        if ( $log->ip_address ) { \WP_CLI::log( 'IP Address: ' . $log->ip_address ); }
        $data = json_decode( $log->log_data, true );
        if ( ! empty( $data ) && is_array( $data ) ) {
            \WP_CLI::log( 'Details:' );
            self::display_data_recursive( $data, 2 );
        } else {
            \WP_CLI::log( 'Details:    (none)' );
        }
        \WP_CLI::log( '-----------------------------' );
    }

    private static function generate_summary( $action, $data ) {
        switch ( $action ) {
            case 'user_registered':
                return "User '" . ( $data['user_login'] ?? 'N/A' ) . "' registered (ID: " . ( $data['user_id'] ?? 'N/A' ) . ")";
            case 'user_deleted':
                $s = "User '" . ( $data['deleted_user_login'] ?? 'N/A' ) . "' (ID: " . ( $data['deleted_user_id'] ?? 'N/A' ) . ") deleted";
                if ( ! empty( $data['reassigned_to_user_id'] ) ) { $s .= ", posts -> ID:{$data['reassigned_to_user_id']}"; }
                return $s;
            case 'user_role_changed':
                $old = implode( ', ', $data['old_roles'] ?? [] );
                $new = implode( ', ', $data['new_roles'] ?? [] );
                return "User '" . ( $data['target_user_login'] ?? 'N/A' ) . "' roles: [{$old}] -> [{$new}]";
            case 'user_super_admin_granted':
                return "Super Admin granted to '" . ( $data['target_user_login'] ?? 'N/A' ) . "'";
            case 'user_super_admin_revoked':
                return "Super Admin revoked from '" . ( $data['target_user_login'] ?? 'N/A' ) . "'";
            case 'user_password_changed':
                $method = $data['method'] ?? 'unknown';
                return "Password changed for '" . ( $data['target_user_login'] ?? 'N/A' ) . "' via {$method}";
            case 'password_reset_requested':
                $kind      = $data['kind'] ?? 'unknown';
                $submitted = $data['submitted'] ?? 'N/A';
                $target    = $data['target_user_login'] ?? null;
                $found     = ! empty( $data['user_found'] );
                $s = "Reset requested ({$kind}) submitted='{$submitted}'";
                if ( $found && $target ) {
                    $s .= " -> matched '{$target}'";
                } else {
                    $s .= ' -> no match';
                }
                return $s;
            case 'plugin_installed': case 'plugin_activated': case 'plugin_deactivated': case 'plugin_deleted':
                $name = $data['plugin']['name'] ?? 'N/A';
                $ver  = $data['plugin']['version'] ?? '';
                return "Plugin '{$name}'" . ( $ver ? " v{$ver}" : '' );
            case 'plugin_updated':
                return "Plugin '" . ( $data['plugin']['name'] ?? 'N/A' ) . "': " . ( $data['old_version'] ?? '?' ) . " -> " . ( $data['new_version'] ?? '?' );
            case 'theme_installed': case 'theme_activated': case 'theme_deleted':
                $name = $data['theme']['name'] ?? 'N/A';
                $ver  = $data['theme']['version'] ?? '';
                return "Theme '{$name}'" . ( $ver ? " v{$ver}" : '' );
            case 'theme_updated':
                return "Theme '" . ( $data['theme']['name'] ?? 'N/A' ) . "': " . ( $data['old_version'] ?? '?' ) . " -> " . ( $data['new_version'] ?? '?' );
            case 'option_added': case 'option_updated':
                return "Option '" . ( $data['option_name'] ?? 'N/A' ) . "'";
            case 'system_core_updated':
                $method = $data['update_method'] ?? '';
                return "Core updated to " . ( $data['new_version'] ?? 'N/A' ) . ( $method ? " ({$method})" : '' );
            case 'system_auto_updated':
                $name = $data['item_name'] ?? 'N/A';
                $ver  = $data['item_version'] ?? 'N/A';
                $s    = "Auto-update: " . ( $data['update_type'] ?? '' ) . " '{$name}' to v{$ver}";
                if ( isset( $data['successful'] ) && ! $data['successful'] ) { $s .= ' (Failed)'; }
                return $s;
            case 'file_editor_saved':
                return ( $data['component_type'] ?? '' ) . " file '" . ( $data['file_path'] ?? 'N/A' ) . "'";
            case 'app_password_created':
                return "App password '" . ( $data['app_name'] ?? 'N/A' ) . "' for user '" . ( $data['target_user_login'] ?? 'N/A' ) . "'";
            case 'app_password_deleted':
                return "App password '" . ( $data['app_name'] ?? 'N/A' ) . "' deleted for '" . ( $data['target_user_login'] ?? 'N/A' ) . "'";
            case 'wpcode_snippet_created':
            case 'wpcode_snippet_updated':
                return "WPCode snippet '" . ( $data['snippet_title'] ?? 'N/A' ) . "' (" . ( $data['snippet_type'] ?? 'unknown' ) . ")";
            default:
                return '';
        }
    }

    private static function display_data_recursive( $data, $indent = 2 ) {
        foreach ( $data as $key => $value ) {
            $prefix = str_repeat( ' ', $indent );
            $label  = str_replace( '_', ' ', ucwords( (string) $key, '_' ) );
            if ( is_array( $value ) ) {
                if ( empty( $value ) ) {
                    \WP_CLI::log( "{$prefix}{$label}: []" );
                } elseif ( array_keys( $value ) === range( 0, count( $value ) - 1 ) && count( $value ) < 5 ) {
                    $items = array_map( function( $v ) { return is_scalar( $v ) ? (string) $v : '(array)'; }, $value );
                    \WP_CLI::log( "{$prefix}{$label}: [ " . implode( ', ', $items ) . ' ]' );
                } else {
                    \WP_CLI::log( "{$prefix}{$label}:" );
                    self::display_data_recursive( $value, $indent + 2 );
                }
            } elseif ( is_bool( $value ) ) {
                \WP_CLI::log( "{$prefix}{$label}: " . ( $value ? 'true' : 'false' ) );
            } elseif ( is_null( $value ) ) {
                \WP_CLI::log( "{$prefix}{$label}: null" );
            } else {
                $display = (string) $value;
                if ( strlen( $display ) > 500 ) { $display = substr( $display, 0, 500 ) . '... (truncated)'; }
                \WP_CLI::log( "{$prefix}{$label}: {$display}" );
            }
        }
